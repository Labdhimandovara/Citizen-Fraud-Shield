# Trust Verification Engine - Environment Configuration

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# ===== Database =====
DATABASE_PATH=alerts.db
DATABASE_RESET_ON_STARTUP=False

# ===== Gemini AI Assistant =====
# Create a key in Google AI Studio, then copy this file to `.env`.
GEMINI_API_KEY="your gemini key"
# Optional: defaults to gemini-3.5-flash
# GEMINI_MODEL=gemini-3.5-flash

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=app.log

# ===== Security =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000
SECRET_KEY=your-secret-key-here

# ===== Alert Configuration =====
HIGH_RISK_ALERT_THRESHOLD=30
MEDIUM_RISK_ALERT_THRESHOLD=70
AUTO_REPORT_HIGH_RISK=False

# ===== Notification (Future) =====
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=alerts@example.com
# SMTP_PASSWORD=password

# ===== Model Paths =====
COUNTERFEIT_MODEL_PATH=models/counterfeit_detector.tflite
VOICE_MODEL_PATH=models/voice_authenticator.pkl
